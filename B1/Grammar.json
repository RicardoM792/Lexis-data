[
  {
    "topic": "Present Perfect",
    "use": "Acciones pasadas con conexión al presente (experiencia, resultados, tiempo no específico)",
    "structure": {
      "affirmative": "Subject + have/has + past participle",
      "negative": "Subject + have/has not + past participle",
      "question": "Have/Has + subject + past participle?"
    },
    "keywords": ["already","yet","ever","never","just"],
    "examples": {
      "affirmative": ["I have finished.", "She has traveled a lot."],
      "negative": ["I have not finished.", "She has not eaten."],
      "question": ["Have you finished?", "Has she traveled?"]
    },
    "examples_es": {
      "affirmative": ["He terminado.", "Ella ha viajado mucho."],
      "negative": ["No he terminado.", "Ella no ha comido."],
      "question": ["¿Has terminado?", "¿Ella ha viajado?"]
    }
  },

  {
    "topic": "Present Perfect vs Past Simple",
    "use": "Diferenciar entre pasado específico y experiencia general",
    "rules": [
      "Past Simple → tiempo definido (yesterday, last year)",
      "Present Perfect → sin tiempo específico"
    ],
    "examples": [
      "I went yesterday.",
      "I have been there."
    ],
    "examples_es": [
      "Fui ayer.",
      "He estado allí."
    ]
  },

  {
    "topic": "First Conditional",
    "use": "Situaciones reales en el futuro",
    "structure": "If + present simple, will + verb",
    "examples": ["If it rains, I will stay home."],
    "examples_es": ["Si llueve, me quedaré en casa."]
  },

  {
    "topic": "Future Continuous",
    "use": "Acciones en progreso en el futuro",
    "structure": "Subject + will be + verb-ing",
    "examples": ["I will be working tomorrow."],
    "examples_es": ["Estaré trabajando mañana."]
  },

  {
    "topic": "Gerunds (-ing)",
    "use": "Verbos como sustantivos",
    "structure": "Verb + ing",
    "examples": ["Swimming is fun.", "I like reading."],
    "examples_es": ["Nadar es divertido.", "Me gusta leer."]
  },

  {
    "topic": "Infinitives (to + verb)",
    "use": "Expresar propósito o intención",
    "structure": "to + base verb",
    "examples": ["I want to learn.", "She decided to go."],
    "examples_es": ["Quiero aprender.", "Ella decidió ir."]
  },

  {
    "topic": "Gerunds vs Infinitives",
    "use": "Diferenciar uso según verbo",
    "rules": [
      "like, enjoy → gerund",
      "want, need → infinitive"
    ],
    "examples": ["I enjoy reading.", "I want to learn."],
    "examples_es": ["Disfruto leer.", "Quiero aprender."]
  },

  {
    "topic": "Modal Verbs (May / Might)",
    "use": "Posibilidad",
    "structure": "Subject + may/might + verb",
    "examples": ["It may rain.", "She might come."],
    "examples_es": ["Puede que llueva.", "Tal vez ella venga."]
  },

  {
    "topic": "Phrasal Verbs (Basic)",
    "use": "Verbos compuestos comunes",
    "examples": [
      "get up (levantarse)",
      "turn on (encender)",
      "look for (buscar)"
    ],
    "examples_es": [
      "get up = levantarse",
      "turn on = encender",
      "look for = buscar"
    ]
  },

  {
    "topic": "Adjectives vs Adverbs",
    "use": "Diferenciar descripción vs acción",
    "rules": [
      "Adjective → describe noun",
      "Adverb → describe verb (+ly)"
    ],
    "examples": ["She is quick.", "She runs quickly."],
    "examples_es": ["Ella es rápida.", "Ella corre rápido."]
  },

  {
    "topic": "Relative Clauses (who, which, that)",
    "use": "Dar información adicional",
    "structure": "noun + who/which/that + clause",
    "examples": ["The man who called.", "The book that I read."],
    "examples_es": ["El hombre que llamó.", "El libro que leí."]
  },

  {
    "topic": "Quantifiers",
    "use": "Cantidad",
    "list": ["a lot of","plenty of","few","little"],
    "examples": ["A lot of people.", "Few options."],
    "examples_es": ["Mucha gente.", "Pocas opciones."]
  },

  {
    "topic": "Linking Words",
    "use": "Conectar ideas",
    "list": ["and","but","because","so","although"],
    "examples": ["I went because I wanted."],
    "examples_es": ["Fui porque quería."]
  }
]
