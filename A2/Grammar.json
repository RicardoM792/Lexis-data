[
  {
    "topic": "Past Simple (Regular & Irregular)",
    "use": "Acciones terminadas en el pasado",
    "structure": {
      "affirmative": "Subject + verb (past)",
      "negative": "Subject + did not + base verb",
      "question": "Did + subject + base verb?"
    },
    "rules": [
      "Verbos regulares → +ed",
      "Irregulares → forma propia (go → went)",
      "Después de 'did' el verbo vuelve a base"
    ],
    "examples": {
      "affirmative": ["I worked yesterday.", "She went home."],
      "negative": ["I did not work.", "She did not go."],
      "question": ["Did you work?", "Did she go?"]
    },
    "examples_es": {
      "affirmative": ["Trabajé ayer.", "Ella fue a casa."],
      "negative": ["No trabajé.", "Ella no fue."],
      "question": ["¿Trabajaste?", "¿Ella fue?"]
    }
  },

  {
    "topic": "Used To",
    "use": "Hábitos o estados en el pasado que ya no ocurren",
    "structure": "Subject + used to + verb",
    "examples": ["I used to play soccer.", "She used to live here."],
    "examples_es": ["Solía jugar fútbol.", "Ella solía vivir aquí."]
  },

  {
    "topic": "Comparatives",
    "use": "Comparar dos cosas",
    "structure": {
      "short_adj": "adjective + er + than",
      "long_adj": "more + adjective + than"
    },
    "rules": [
      "Adjetivos cortos → taller",
      "Adjetivos largos → more beautiful",
      "Irregulares: good → better"
    ],
    "examples": ["She is taller than me.", "This is more expensive."],
    "examples_es": ["Ella es más alta que yo.", "Esto es más caro."]
  },

  {
    "topic": "Superlatives",
    "use": "Comparar más de dos cosas",
    "structure": {
      "short_adj": "the + adjective + est",
      "long_adj": "the most + adjective"
    },
    "examples": ["She is the tallest.", "This is the most expensive."],
    "examples_es": ["Ella es la más alta.", "Esto es lo más caro."]
  },

  {
    "topic": "Future (Going To)",
    "use": "Planes e intenciones",
    "structure": {
      "affirmative": "Subject + am/is/are + going to + verb",
      "negative": "Subject + am/is/are not + going to + verb",
      "question": "Am/Is/Are + subject + going to + verb?"
    },
    "examples": ["I am going to study.", "She is going to travel."],
    "examples_es": ["Voy a estudiar.", "Ella va a viajar."]
  },

  {
    "topic": "Future (Will)",
    "use": "Decisiones espontáneas, promesas, predicciones",
    "structure": {
      "affirmative": "Subject + will + verb",
      "negative": "Subject + will not + verb",
      "question": "Will + subject + verb?"
    },
    "examples": ["I will help you.", "She will call."],
    "examples_es": ["Te ayudaré.", "Ella llamará."]
  },

  {
    "topic": "Modal Verbs (Must / Have To)",
    "use": "Obligación",
    "structure": {
      "must": "Subject + must + verb",
      "have_to": "Subject + have to + verb"
    },
    "examples": ["You must study.", "I have to work."],
    "examples_es": ["Debes estudiar.", "Tengo que trabajar."]
  },

  {
    "topic": "Modal Verbs (Should)",
    "use": "Consejos y recomendaciones",
    "structure": "Subject + should + verb",
    "examples": ["You should sleep.", "She should eat healthy."],
    "examples_es": ["Deberías dormir.", "Ella debería comer saludable."]
  },

  {
    "topic": "Adverbs of Frequency",
    "use": "Frecuencia de acciones",
    "position": "Antes del verbo principal",
    "list": ["always","usually","often","sometimes","never"],
    "examples": ["I always wake up early.", "She never eats fast food."],
    "examples_es": ["Siempre me levanto temprano.", "Ella nunca come comida rápida."]
  },

  {
    "topic": "Prepositions of Time",
    "use": "Tiempo",
    "rules": [
      "in → meses, años",
      "on → días",
      "at → horas"
    ],
    "examples": ["In 2020.", "On Monday.", "At 5 pm."],
    "examples_es": ["En 2020.", "El lunes.", "A las 5 pm."]
  },

  {
    "topic": "Countable / Uncountable Nouns",
    "use": "Diferenciar sustantivos contables y no contables",
    "structure": {
      "countable": "many / a few",
      "uncountable": "much / a little"
    },
    "examples": ["Many apples.", "Much water."],
    "examples_es": ["Muchas manzanas.", "Mucha agua."]
  },

  {
    "topic": "Some / Any",
    "use": "Cantidades indefinidas",
    "rules": [
      "some → afirmativas",
      "any → negativas y preguntas"
    ],
    "examples": ["I have some money.", "Do you have any water?"],
    "examples_es": ["Tengo dinero.", "¿Tienes agua?"]
  }
]
